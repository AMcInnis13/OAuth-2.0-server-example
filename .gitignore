# Environment variables — never commit these
.env
.env.local
.env.*.local

# Database file — contains real user data and hashed secrets
*.db
*.sqlite
*.sqlite3

# Dependencies — restored with npm install
node_modules/

# npm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor folders
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Runtime
*.log
pids/
*.pid
*.seed

# Build output (if you add a build step later)
dist/
build/
